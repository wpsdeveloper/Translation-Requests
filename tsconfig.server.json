{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "None",
    "noLib": false,
    "strict": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src/server",
    "types": ["google-apps-script"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/shared/*.ts", "src/server/**/*"],
  "exclude": ["src/test/**/*", "src/client/**/*"]
}
